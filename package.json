{
  "name": "@transmitt0r/openclaw-plugin-paperless-ngx",
  "version": "0.4.1",
  "description": "OpenClaw plugin for paperless-ngx",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "paperless-ngx",
    "paperless",
    "document-management"
  ],
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || >=24.0.0"
  },
  "packageManager": "pnpm@11.13.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Transmitt0r/openclaw-plugin-paperless-ngx.git"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "openclaw": ">=2026.7.0",
      "pluginApi": ">=2026.7.0"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "generate:types": "tsx scripts/generate-types.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.0"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "typebox": "^1.3.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.23.1",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
